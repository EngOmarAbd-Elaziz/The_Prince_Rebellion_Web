@using AdventureGameWeb.Engine
@using AdventureGameWeb.Services
@inject IGameEngineService GameEngine
@inject AudioService AudioService

<div class="modal-backdrop animate-fade-in">
    <div class="glass-panel modal-content-card animate-pulse">
        <div class="speaker-avatar" style="margin: 0 auto; width: 64px; height: 64px; display: flex; align-items: center; justify-content: center; background: rgba(56, 189, 248, 0.15); border-radius: 50%;">
            <SvgIcon Name="crown" Size="2.5rem" Color="var(--accent-primary)" />
        </div>
        <h2 style="color: var(--accent-primary); font-family: var(--font-heading);">Queen</h2>
        <p style="font-size: 1.25rem; color: var(--text-main);">
            "Good morning, @(GameEngine.Player?.SelectedHero == "Princess" ? "princess" : "prince")."
        </p>
        
        <div style="margin-top: 1rem; text-align: left;">
            <label style="font-size: 0.9rem; color: var(--text-muted); display: block; margin-bottom: 0.5rem;">
                Enter Your Character Name:
            </label>
            <input type="text" 
                   class="input-fantasy" 
                   placeholder="@(GameEngine.Player?.SelectedHero == "Princess" ? "Princess" : "Prince")" 
                   @bind="playerName" 
                   @bind:event="oninput"
                   @onkeyup="HandleKeyUp" />
        </div>

        <button class="btn-fantasy btn-success" style="width: 100%; margin-top: 0.5rem; justify-content: center; gap: 0.5rem;" @onclick="SubmitName">
            <span>Begin the Rebellion</span>
            <SvgIcon Name="arrow-right" Size="1.1rem" />
        </button>
    </div>
</div>

@code {
    private string playerName = "Prince";

    protected override void OnInitialized()
    {
        if (GameEngine.Player?.SelectedHero == "Princess")
        {
            playerName = "Princess";
        }
    }

    private async Task SubmitName()
    {
        await AudioService.PlayClickAsync();
        string hero = GameEngine.Player?.SelectedHero ?? "Prince";
        GameEngine.StartGame(playerName, hero);
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SubmitName();
        }
    }
}
