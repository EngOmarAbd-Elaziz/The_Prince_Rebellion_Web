@using AdventureGameWeb.Engine
@using AdventureGameWeb.Services
@inject IGameEngineService GameEngine
@inject AudioService AudioService
@implements IDisposable

<div class="modal-backdrop animate-fade-in" @onclick="Close">
    <!-- GAME PAUSED Banner Indicator -->
    <div class="pause-banner-wrapper">
        <div class="pause-banner">
            <span><SvgIcon Name="pause" Size="1rem" Color="var(--color-warning)" /> GAME PAUSED</span>
        </div>
    </div>

    <!-- Journal Window - Slide From Right Animation -->
    <div class="glass-panel modal-content-card anim-slide-right" style="max-width: 700px; max-height: 80vh; display: flex; flex-direction: column;" @onclick:stopPropagation="true">
        <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-light); padding-bottom: 0.75rem;">
            <h2 class="font-heading" style="color: var(--accent-primary); display: flex; align-items: center; gap: 0.5rem;">
                <SvgIcon Name="journal" Size="1.4rem" Color="var(--accent-primary)" /> Story Journal
            </h2>
            <button class="btn-quick-icon" @onclick="Close">
                <SvgIcon Name="close" Size="1.1rem" />
            </button>
        </div>

        <div style="flex: 1; overflow-y: auto; text-align: left; padding: 1rem 0; display: flex; flex-direction: column; gap: 0.85rem;">
            @if (GameEngine.DialogueHistory.Count == 0)
            {
                <div style="color: var(--text-muted); text-align: center; padding: 2rem;">No journal entries recorded yet.</div>
            }
            else
            {
                @foreach (var msg in GameEngine.DialogueHistory)
                {
                    <div style="background: rgba(15, 23, 42, 0.6); padding: 0.85rem; border-radius: 8px; border-left: 3px solid var(--accent-primary);">
                        <div style="font-weight: 700; color: var(--accent-primary); font-size: 0.9rem; display: flex; align-items: center; gap: 0.4rem;">
                            <SvgIcon Name="scroll" Size="0.9rem" Color="var(--accent-primary)" />
                            <span>@msg.Speaker</span>
                        </div>
                        <div style="color: var(--text-main); font-size: 0.95rem; margin-top: 0.35rem;">
                            @msg.Text
                        </div>
                    </div>
                }
            }
        </div>

        <button class="btn-fantasy" style="width: 100%; margin-top: 0.5rem;" @onclick="Close">Resume Game</button>
    </div>
</div>

<style>
    .pause-banner-wrapper {
        position: absolute;
        top: 25px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 10005;
        pointer-events: none;
    }

    .pause-banner {
        background: rgba(15, 23, 42, 0.95);
        border: 1px solid var(--color-warning);
        border-radius: 20px;
        padding: 0.4rem 1.5rem;
        font-family: var(--font-heading);
        font-weight: 700;
        font-size: 0.95rem;
        color: var(--color-warning);
        letter-spacing: 0.1em;
        backdrop-filter: blur(8px);
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }
</style>

@code {
    [Parameter] public EventCallback OnClose { get; set; }

    protected override async Task OnInitializedAsync()
    {
        GameEngine.PauseGame();
        await AudioService.PlayModalOpenAsync();
    }

    public void Dispose()
    {
        GameEngine.ResumeGame();
    }

    private async Task Close()
    {
        await AudioService.PlayModalCloseAsync();
        GameEngine.ResumeGame();
        await OnClose.InvokeAsync();
    }
}
