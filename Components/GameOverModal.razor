@using AdventureGameWeb.Engine
@using AdventureGameWeb.Services
@inject IGameEngineService GameEngine
@inject AudioService AudioService
@inject IJSRuntime JSRuntime
@inject UiStateService UiState
@inject AchievementService AchievementService
@inject SupabaseLeaderboardService SupabaseService

@if (GameEngine.CurrentPhase == GamePhase.GameOver)
{
    <div class="modal-backdrop animate-fade-in">
        <div class="glass-panel modal-content-card"
             style="border-color: var(--color-danger); box-shadow: 0 0 35px rgba(239, 68, 68, 0.4);">
            <div class="speaker-avatar"
                 style="margin: 0 auto; width: 80px; height: 80px; background: rgba(239, 68, 68, 0.15); display: flex; align-items: center; justify-content: center; border-radius: 50%;">
                <SvgIcon Name="skull" Size="3rem" Color="var(--color-danger)" />
            </div>

            <h1 class="font-heading" style="color: var(--color-danger); font-size: 2.2rem;">
                DEFEATED
            </h1>

            <p style="font-size: 1.2rem; color: var(--text-main);">
                You were defeated in battle. The rebellion has fallen...
            </p>

            <!-- Score Card -->
            <div
                style="background: rgba(15, 23, 42, 0.6); padding: 1rem; border-radius: 10px; border: 1px solid var(--border-light); text-align: left;">
                <div style="font-size: 0.9rem; color: var(--text-muted);">Final Stats:</div>
                <div
                    style="margin-top: 0.5rem; display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; font-weight: 600;">
                    <span style="display: flex; align-items: center; gap: 0.4rem;">
                        <SvgIcon Name="coins" Size="1rem" Color="var(--color-warning)" /> Coins: @GameEngine.Player.Coins
                    </span>
                    <span style="display: flex; align-items: center; gap: 0.4rem;">
                        <SvgIcon Name="event" Size="1rem" Color="var(--accent-primary)" /> Rooms: @GameEngine.RoomNumber
                    </span>
                    <span style="display: flex; align-items: center; gap: 0.4rem;">
                        <SvgIcon Name="chain" Size="1rem" Color="var(--color-danger)" /> Prisoners Left:
                        @GameEngine.Player.PrisonersRemaining
                    </span>
                    <span style="display: flex; align-items: center; gap: 0.4rem;">
                        <SvgIcon Name="achievements" Size="1rem" Color="var(--accent-primary)" /> Achievements:
                        @_achievementsCount
                    </span>
                </div>
            </div>

            <div
                style="background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.3); border-radius: 10px; padding: 0.75rem 1rem; text-align: center;">
                <div style="font-size: 0.8rem; color: var(--text-muted);">FINAL SCORE</div>
                <div class="font-heading" style="font-size: 2.2rem; color: var(--color-warning); font-weight: 900;">
                    @_finalScore</div>
                    @if (!string.IsNullOrWhiteSpace(GameEngine.Player?.Name))
                    {
                        <div style="font-size: 0.82rem; color: var(--text-muted); margin-top: 0.2rem;">Recorded as: <strong
                            style="color: var(--text-main);">@GameEngine.Player.Name</strong></div>
                    }
                        @if (_scoreSubmitted)
                        {
                            <div style="font-size: 0.78rem; color: var(--color-success); margin-top: 0.3rem;">✓ High score saved to
                                leaderboard</div>
                            }
                        </div>

                        <button class="btn-fantasy btn-danger"
                                style="width: 100%; margin-top: 0.5rem; justify-content: center; gap: 0.5rem;" @onclick="Restart"
                                disabled="@_isSaving">
                            <SvgIcon Name="sword" Size="1.1rem" />
                            @if (_isSaving)
                            {
                                <span> Saving...</span>
                            }
                            else
                            {
                                <span> Return to Home</span>
                            }
                        </button>
                    </div>
                </div>
            }

@code {
    private int _finalScore;
    private int _achievementsCount;
    private bool _scoreSubmitted;
    private bool _isSaving = false;

    protected override async Task OnInitializedAsync()
    {
        GameEngine.OnChange += StateHasChanged;
        await AudioService.PlayTrackAsync("Defeat");
        _isSaving = true;
        _scoreSubmitted = await SubmitScoreAsync();
        _isSaving = false;
    }

    public void Dispose()
    {
        GameEngine.OnChange -= StateHasChanged;
    }

    private async Task<bool> SubmitScoreAsync()
    {
        _achievementsCount = AchievementService.Achievements.Count(a => a.IsUnlocked);
        _finalScore = GameEngine.CalculateScore(false);
        _finalScore += _achievementsCount * 30;
        StateHasChanged();

        var username = GameEngine.Player?.Name?.Trim() ?? string.Empty;
        if (string.IsNullOrWhiteSpace(username))
        {
            return false;
        }

        var result = await SupabaseService.SubmitScoreAsync(new LeaderboardEntry
        {
            Username = username,
            CharacterClass = GameEngine.Player?.SelectedHero ?? "Prince",
            Score = _finalScore,
            PlayTimeSeconds = GameEngine.PlayTimeSeconds,
            AchievementsCount = _achievementsCount,
            IsVictory = false
        });
        _scoreSubmitted = result;
        StateHasChanged();
        return result;
    }

    private async Task Restart()
    {
        await AudioService.PlayClickAsync();
        try { await JSRuntime.InvokeVoidAsync("triggerCinematicReturnToHome"); } catch { }
        GameEngine.RestartGame();
        UiState.SetLandingPage(true);
    }
}
