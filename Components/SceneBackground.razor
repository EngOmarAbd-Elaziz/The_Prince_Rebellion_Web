@using AdventureGameWeb.Engine
@inject IGameEngineService GameEngine

<div class="scene-background @GetSceneCssClass()">
    <div class="scene-overlay"></div>
    <div class="scene-ambient-glow"></div>
</div>

<style>
    .scene-background {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        z-index: 0;
        transition: background 1.2s cubic-bezier(0.4, 0, 0.2, 1);
        pointer-events: none;
    }

    .scene-overlay {
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at 50% 50%, rgba(15, 23, 42, 0.4) 0%, rgba(15, 23, 42, 0.85) 100%);
    }

    .scene-ambient-glow {
        position: absolute;
        top: 20%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 60vw;
        height: 60vh;
        border-radius: 50%;
        filter: blur(80px);
        opacity: 0.15;
        transition: background 1.5s ease;
    }

    /* Scene Variations */
    .scene-PalaceBedroom {
        background: linear-gradient(135deg, #1E1B4B 0%, #0F172A 100%);
    }
    .scene-PalaceBedroom .scene-ambient-glow {
        background: #818CF8;
    }

    .scene-PalaceHall {
        background: linear-gradient(135deg, #311B92 0%, #0F172A 100%);
    }
    .scene-PalaceHall .scene-ambient-glow {
        background: #A78BFA;
    }

    .scene-TownMarket {
        background: linear-gradient(135deg, #451A03 0%, #0F172A 100%);
    }
    .scene-TownMarket .scene-ambient-glow {
        background: #F59E0B;
    }

    .scene-BunkerHideout {
        background: linear-gradient(135deg, #18181B 0%, #0F172A 100%);
    }
    .scene-BunkerHideout .scene-ambient-glow {
        background: #EF4444;
    }

    .scene-PrisonShipChains {
        background: linear-gradient(135deg, #022C22 0%, #0F172A 100%);
    }
    .scene-PrisonShipChains .scene-ambient-glow {
        background: #10B981;
    }

    .scene-ShipDeck {
        background: linear-gradient(135deg, #0C4A6E 0%, #0F172A 100%);
    }
    .scene-ShipDeck .scene-ambient-glow {
        background: #38BDF8;
    }

    .scene-ShipRoof {
        background: linear-gradient(135deg, #1E293B 0%, #0F172A 100%);
    }
    .scene-ShipRoof .scene-ambient-glow {
        background: #FACC15;
    }

    .scene-TownBattlefield {
        background: linear-gradient(135deg, #7F1D1D 0%, #0F172A 100%);
    }
    .scene-TownBattlefield .scene-ambient-glow {
        background: #F87171;
    }

    .scene-KingThroneRoom {
        background: linear-gradient(135deg, #581C87 0%, #0F172A 100%);
    }
    .scene-KingThroneRoom .scene-ambient-glow {
        background: #C084FC;
    }
</style>

@code {
    protected override void OnInitialized()
    {
        GameEngine.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        GameEngine.OnChange -= StateHasChanged;
    }

    private string GetSceneCssClass()
    {
        return $"scene-{GameEngine.CurrentSceneBackground}";
    }
}
