@using AdventureGameWeb.Services
@using AdventureGameWeb.Engine
@inject AchievementService AchievementService
@inject IGameEngineService GameEngine
@inject AudioService AudioService
@implements IDisposable

<div class="modal-backdrop animate-fade-in" @onclick="Close">
    <!-- GAME PAUSED Banner Indicator -->
    <div class="pause-banner-wrapper">
        <div class="pause-banner">
            <span><SvgIcon Name="pause" Size="1rem" Color="var(--color-warning)" /> GAME PAUSED</span>
        </div>
    </div>

    <!-- Achievements Window - Rise From Bottom Animation -->
    <div class="glass-panel modal-content-card anim-rise-bottom" style="max-width: 700px; max-height: 80vh; display: flex; flex-direction: column;" @onclick:stopPropagation="true">
        <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-light); padding-bottom: 0.75rem;">
            <h2 class="font-heading" style="color: var(--color-warning); display: flex; align-items: center; gap: 0.5rem;">
                <SvgIcon Name="achievements" Size="1.4rem" Color="var(--color-warning)" /> Achievements & Trophy Badges
            </h2>
            <button class="btn-quick-icon" @onclick="Close">
                <SvgIcon Name="close" Size="1.1rem" Color="#FFF" />
            </button>
        </div>

        <div style="flex: 1; overflow-y: auto; display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1rem; padding: 1rem 0; text-align: left;">
            @foreach (var ach in AchievementService.Achievements)
            {
                string iconName = GetAchievementIcon(ach.Id);
                <div class="glass-card" style="border-color: @(ach.IsUnlocked ? "var(--color-warning)" : "var(--border-light)"); opacity: @(ach.IsUnlocked ? "1" : "0.55"); display: flex; gap: 0.85rem; align-items: center; background: @(ach.IsUnlocked ? "rgba(250, 204, 21, 0.08)" : "rgba(30, 41, 59, 0.4)");">
                    <div style="width: 46px; height: 46px; border-radius: 50%; background: rgba(15, 23, 42, 0.85); display: flex; align-items: center; justify-content: center; flex-shrink: 0; border: 1.5px solid @(ach.IsUnlocked ? "var(--color-warning)" : "var(--border-light)"); box-shadow: @(ach.IsUnlocked ? "0 0 12px rgba(250, 204, 21, 0.3)" : "none"); overflow: hidden;">
                        <img src="images/achievement_trophy.png" alt="Trophy" style="width: 100%; height: 100%; object-fit: cover; opacity: @(ach.IsUnlocked ? "1" : "0.4"); filter: @(ach.IsUnlocked ? "none" : "grayscale(100%)");" />
                    </div>
                    <div>
                        <div style="font-family: var(--font-heading); font-weight: 700; color: @(ach.IsUnlocked ? "var(--color-warning)" : "var(--text-muted)"); font-size: 1.05rem;">
                            @ach.Title
                        </div>
                        <div style="font-size: 0.85rem; color: var(--text-muted); margin-top: 0.2rem;">
                            @ach.Description
                        </div>
                        @if (ach.IsUnlocked && ach.UnlockedAt.HasValue)
                        {
                            <div style="font-size: 0.75rem; color: var(--color-success); margin-top: 0.35rem; font-weight: 600;">
                                Unlocked: @ach.UnlockedAt.Value.ToString("MMM dd, HH:mm")
                            </div>
                        }
                        else
                        {
                            <div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 0.35rem; font-style: italic;">
                                Locked
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        <button class="btn-fantasy" style="width: 100%; margin-top: 0.5rem;" @onclick="Close">Resume Game</button>
    </div>
</div>

<style>
    .pause-banner-wrapper {
        position: absolute;
        top: 25px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 10005;
        pointer-events: none;
    }

    .pause-banner {
        background: rgba(15, 23, 42, 0.95);
        border: 1px solid var(--color-warning);
        border-radius: 20px;
        padding: 0.4rem 1.5rem;
        font-family: var(--font-heading);
        font-weight: 700;
        font-size: 0.95rem;
        color: var(--color-warning);
        letter-spacing: 0.1em;
        backdrop-filter: blur(8px);
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }
</style>

@code {
    [Parameter] public EventCallback OnClose { get; set; }

    protected override async Task OnInitializedAsync()
    {
        GameEngine.PauseGame();
        await AudioService.PlayModalOpenAsync();
    }

    public void Dispose()
    {
        GameEngine.ResumeGame();
    }

    private string GetAchievementIcon(string id)
    {
        return id switch
        {
            "revolution_begins" => "sword",
            "chains_broken" => "chain",
            "first_blood" => "target",
            "treasure_hunter" => "coins",
            "freedom_fighter" => "shield",
            "captain_down" => "skull",
            "king_slayer" => "crown",
            _ => "achievements"
        };
    }

    private async Task Close()
    {
        await AudioService.PlayModalCloseAsync();
        GameEngine.ResumeGame();
        await OnClose.InvokeAsync();
    }
}
