@using AdventureGameWeb.Engine
@inject IGameEngineService GameEngine

@if (GameEngine.CurrentPhase == GamePhase.EventNotification && !string.IsNullOrEmpty(GameEngine.EventMessage))
{
    <div class="event-card-container animate-fade-in">
        <div class="glass-panel event-card-wrapper" style="border-color: var(--accent-primary); box-shadow: 0 20px 60px rgba(0, 0, 0, 0.85), 0 0 35px var(--accent-glow);">
            <div class="event-card-body">
                <div class="event-card-icon">
                    <SvgIcon Name="event" Size="2.2rem" Color="var(--accent-primary)" />
                </div>
                <div class="event-card-text">
                    <h3 class="font-heading event-card-title">Event Notification</h3>
                    <p class="event-card-message">
                        @GameEngine.EventMessage
                    </p>
                </div>
            </div>

            <div class="event-card-footer">
                <button class="btn-fantasy btn-success" style="display: inline-flex; align-items: center; gap: 0.5rem;" @onclick="Dismiss">
                    <span>Continue Exploration</span>
                    <SvgIcon Name="arrow-right" Size="1.1rem" />
                </button>
            </div>
        </div>
    </div>
}

<style>
    .event-card-container {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: min(650px, 94%);
        max-height: calc(100% - 1rem);
        z-index: 6500;
        overflow-y: auto;
        -webkit-overflow-scrolling: touch;
    }

    .event-card-wrapper {
        padding: 2rem;
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
        background: rgba(30, 41, 59, 0.96);
        border-radius: 20px;
        backdrop-filter: blur(24px);
    }

    .event-card-body {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        text-align: left;
    }

    .event-card-icon {
        background: rgba(56, 189, 248, 0.15);
        width: 64px;
        height: 64px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .event-card-title {
        color: var(--accent-primary);
        font-size: 1.3rem;
    }

    .event-card-message {
        font-size: 1.2rem;
        color: var(--text-main);
        margin-top: 0.4rem;
        font-weight: 500;
        line-height: 1.5;
    }

    .event-card-footer {
        display: flex;
        justify-content: flex-end;
        border-top: 1px solid var(--border-light);
        padding-top: 1rem;
        margin-top: 0.5rem;
    }

    @@media (max-width: 768px) {
        .event-card-body {
            flex-direction: column;
            text-align: center;
        }

        .event-card-footer {
            justify-content: stretch;
        }

        .event-card-footer .btn-fantasy {
            width: 100%;
        }
    }
</style>

@code {
    protected override void OnInitialized()
    {
        GameEngine.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        GameEngine.OnChange -= StateHasChanged;
    }

    private void Dismiss()
    {
        GameEngine.DismissEventCard();
    }
}
